#!/usr/bin/env bash
# lemux — a tmux-native, node-based navigator for branched Claude Code sessions.
# Branch from a highlighted excerpt, wander deep, jump around, delete side quests.
set -euo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
LEMUX_DIR="${LEMUX_DIR:-$HOME/.lemux}"
TREE="$LEMUX_DIR/tree.json"
CLAUDE_BIN="${LEMUX_CLAUDE:-$(command -v claude || echo "$HOME/.local/bin/claude")}"
CLAUDE_PROJECTS="$HOME/.claude/projects"

# ---------- helpers ----------

die() {
  echo "lemux: $*" >&2
  [[ -n "${TMUX:-}" ]] && tmux display-message "lemux: $*" || true
  exit 1
}

init_state() {
  mkdir -p "$LEMUX_DIR"
  [[ -f "$TREE" ]] || echo '[]' >"$TREE"
}

munge() { printf '%s' "$1" | sed 's/[^A-Za-z0-9]/-/g'; }

new_uuid() { uuidgen | tr '[:upper:]' '[:lower:]'; }

jq_update() {
  local tmp
  tmp=$(mktemp "$LEMUX_DIR/.tree.XXXXXX")
  jq "$@" "$TREE" >"$tmp" && mv "$tmp" "$TREE"
}

node_field() { jq -r --arg id "$1" ".[] | select(.id==\$id) | .$2 // \"\"" "$TREE"; }

# The session a side quest ultimately hangs off — the navigator's scope.
root_of() {
  local id="$1" p
  while p=$(node_field "$id" parent); [[ -n "$p" ]]; do id="$p"; done
  printf '%s' "$id"
}

descendants() { # id — print the id and every descendant id, one per line (BFS)
  local frontier=("$1") next p kids
  printf '%s\n' "$1"
  while ((${#frontier[@]})); do
    next=()
    for p in "${frontier[@]}"; do
      kids=($(jq -r --arg id "$p" '.[] | select(.parent==$id) | .id' "$TREE"))
      ((${#kids[@]})) && { printf '%s\n' "${kids[@]}"; next+=("${kids[@]}"); }
    done
    frontier=("${next[@]:-}")
    [[ -z "${frontier[0]:-}" ]] && frontier=()
  done
}

add_node() { # id parent name excerpt dir
  jq_update --arg id "$1" --arg parent "$2" --arg name "$3" \
    --arg excerpt "$4" --arg dir "$5" --argjson created "$(date +%s)" \
    '. + [{id:$id, parent:$parent, name:$name, excerpt:$excerpt, dir:$dir,
           created:$created, window:"", pane:""}]'
}

window_alive() {
  [[ -n "$1" ]] && tmux list-windows -a -F '#{window_id}' 2>/dev/null | grep -qx "$1"
}

session_file() { # id dir
  printf '%s/%s/%s.jsonl' "$CLAUDE_PROJECTS" "$(munge "$2")" "$1"
}

collapse_ws() { tr '\n\t\r' '   ' | sed -E 's/ +/ /g; s/^ //; s/ $//'; }

# Whatever the user last selected: system clipboard first (macOS mouse
# selection + cmd-C), then tmux's own paste buffer (tmux copy-mode / mouse).
get_clip() {
  local t=""
  if command -v pbpaste >/dev/null 2>&1; then t=$(pbpaste 2>/dev/null || true); fi
  if [[ -z "${t//[[:space:]]/}" ]]; then t=$(tmux show-buffer 2>/dev/null || true); fi
  printf '%s' "$t"
}

# die, but visibly — inside a popup, stderr vanishes the instant we exit.
popup_die() {
  printf '\n  \033[1mlemux:\033[0m %s\n\n  press any key…' "$*"
  read -n 1 -s -r </dev/tty 2>/dev/null || sleep 3
  exit 1
}

# Type text into a freshly spawned claude pane once its UI has rendered.
# The typist is handed to the tmux server so it outlives us — we're usually
# a popup that closes the moment this returns. The text goes via a file so
# tmux's format expansion can't mangle a '#' in the excerpt.
_prefill() { # pane text submit(0|1)
  local pane="$1" text="$2" submit="$3" f
  f=$(mktemp "$LEMUX_DIR/.seed.XXXXXX")
  printf '%s' "$text" >"$f"
  tmux run-shell -b "$(printf '%q' "$SELF") _type $(printf '%q' "$pane") $(printf '%q' "$f") $submit"
}

cmd__type() { # pane seedfile submit — wait for claude's input box, then type
  local pane="$1" seedfile="$2" submit="$3" i out text
  text=$(cat "$seedfile" 2>/dev/null || true)
  rm -f "$seedfile"
  [[ -n "$text" ]] || return 0
  for i in $(seq 1 120); do
    sleep 0.25
    out=$(tmux capture-pane -p -t "$pane" 2>/dev/null || true)
    case "$out" in *"for shortcuts"*) break ;; esac
  done
  sleep 0.8
  tmux send-keys -t "$pane" -l -- "$text" 2>/dev/null || true
  if [[ "$submit" == 1 ]]; then
    sleep 0.5
    tmux send-keys -t "$pane" Enter 2>/dev/null || true
  fi
}

# ---------- commands ----------

cmd_start() { # <name> — enter a topic: resume the root if it exists, create it if not
  [[ -n "${TMUX:-}" ]] || die "start must be run inside tmux"
  init_state
  local name="${1:-}" id win mode
  [[ -n "$name" ]] || die "usage: lemux start <name>   (lemux ls shows existing topics)"
  id=$(jq -r --arg n "$name" --arg d "$PWD" \
    '[.[] | select(.parent=="" and .name==$n and .dir==$d)] | first // {} | .id // ""' "$TREE")
  if [[ -n "$id" ]]; then
    win=$(node_field "$id" window)
    if window_alive "$win"; then
      tmux select-window -t "$win"
      return 0
    fi
    mode=revive
    [[ -f "$(session_file "$id" "$(node_field "$id" dir)")" ]] || mode=new
    tmux rename-window "$name"
    exec "$SELF" _run "$id" "$(node_field "$id" dir)" "$mode"
  fi
  id=$(new_uuid)
  add_node "$id" "" "$name" "" "$PWD"
  tmux rename-window "$name"
  exec "$SELF" _run "$id" "$PWD" new
}

cmd_branch() { # <pane_id> [--text <excerpt>] [--ask <question>] — fork the pane's session
  init_state
  local pane excerpt="" question=""
  pane="${1:?usage: lemux branch <pane_id> [--text <excerpt>] [--ask <question>]}"
  shift
  while (($#)); do
    case "$1" in
      --text) shift; excerpt=$(printf '%s' "${1:-}" | collapse_ws) ;;
      --ask)  shift; question=$(printf '%s' "${1:-}" | collapse_ws) ;;
      *)      die "branch: unexpected argument: $1" ;;
    esac
    shift
  done
  [[ -n "$excerpt$question" ]] || die "nothing to branch on — select some text and copy it first"

  local parent dir id name
  parent=$(tmux display-message -t "$pane" -p '#{@lemux_session}' 2>/dev/null || true)
  [[ -n "$parent" ]] || die "this pane is not a lemux session (start one with: lemux start)"
  dir=$(node_field "$parent" dir)
  [[ -n "$dir" ]] || die "unknown parent session $parent"
  [[ -f "$(session_file "$parent" "$dir")" ]] || die "nothing to branch yet — send at least one message first"

  id=$(new_uuid)
  name=$(printf '%s' "${question:-$excerpt}" | cut -c1-28 | tr -cd '[:print:]' | sed -E 's/^ +| +$//g')
  [[ -n "$name" ]] || name="branch"
  add_node "$id" "$parent" "$name" "$excerpt" "$dir"

  local newpane
  newpane=$(tmux new-window -c "$dir" -n "$name" -P -F '#{pane_id}' \
    "exec $(printf '%q' "$SELF") _run $(printf '%q' "$id") $(printf '%q' "$dir") fork $(printf '%q' "$parent")")

  # Seed the fork's input box. With a question we submit it; without one we
  # leave the excerpt sitting there for you to type after.
  local seed submit
  if [[ -n "$excerpt" ]]; then
    seed="Re \"$(printf '%s' "$excerpt" | cut -c1-600)\": $question"
  else
    seed="$question"
  fi
  [[ -n "$question" ]] && submit=1 || submit=0
  _prefill "$newpane" "$seed" "$submit"
}

cmd_ask() { # <pane_id> — popup: confirm the copied excerpt, type a question, branch
  init_state
  local pane="${1:?usage: lemux ask <pane_id>}" parent dir excerpt question shown
  parent=$(tmux display-message -t "$pane" -p '#{@lemux_session}' 2>/dev/null || true)
  [[ -n "$parent" ]] || popup_die "this pane is not a lemux session — start one with: lemux start"
  dir=$(node_field "$parent" dir)
  [[ -n "$dir" ]] || popup_die "unknown parent session"
  [[ -f "$(session_file "$parent" "$dir")" ]] || popup_die "nothing to branch yet — send at least one message first"

  excerpt=$(get_clip | collapse_ws)
  printf '\n  \033[1mbranch a side quest\033[0m  \033[2m(from %s)\033[0m\n\n' "$(node_field "$parent" name)"
  if [[ -n "$excerpt" ]]; then
    shown=$(printf '%s' "$excerpt" | cut -c1-240)
    [[ "${#excerpt}" -gt 240 ]] && shown="$shown…"
    printf '  \033[2mon\033[0m "%s"\n' "$shown"
  else
    printf '  \033[2mnothing copied — the branch will start from your question alone\033[0m\n'
  fi
  printf '\n  \033[2mtype your question and hit enter · empty enter opens the branch so you\n  can type there · ctrl-c cancels\033[0m\n\n'
  read -e -r -p "  > " question || { printf '\n  cancelled\n'; return 0; }
  cmd_branch "$pane" --text "$excerpt" --ask "$question"
}

cmd__popup() { # <width> <height> <subcommand> <pane_id> — called from the tmux bindings
  tmux display-popup -E -w "${1:?}" -h "${2:?}" \
    "$(printf '%q' "$SELF") ${3:?} $(printf '%q' "${4:?}")"
}

cmd__run() { # id dir mode [parent] — wrapper that tags the pane and execs claude
  local id="$1" dir="$2" mode="$3" parent="${4:-}"
  cd "$dir"
  tmux set-option -p @lemux_session "$id"
  tmux set-option -p remain-on-exit failed 2>/dev/null || true
  jq_update --arg id "$id" \
    --arg win "$(tmux display-message -p '#{window_id}')" \
    --arg pane "${TMUX_PANE:-}" \
    'map(if .id==$id then .window=$win | .pane=$pane else . end)'
  local args rc=0
  case "$mode" in
    new)    args=(--session-id "$id") ;;
    fork)   args=(--resume "$parent" --fork-session --session-id "$id") ;;
    revive) args=(--resume "$id") ;;
    *)      die "unknown run mode: $mode" ;;
  esac
  "$CLAUDE_BIN" "${args[@]}" || rc=$?
  ((rc)) && exit "$rc"   # remain-on-exit keeps the pane so the error stays readable

  # Exiting walks you back up the path. Open windows are only ever the chain
  # you're inside (root → … → here), so on exit everything in this topic
  # that isn't an ancestor of where you land is closed. State and
  # transcripts survive — the tree revives any of it.
  local keep=" " p n win pruned
  p=$(node_field "$id" parent)
  n="$p"; while [[ -n "$n" ]]; do keep+="$n "; n=$(node_field "$n" parent); done
  pruned=""
  for n in $(descendants "$(root_of "$id")"); do
    [[ "$keep" == *" $n "* ]] && continue
    pruned+="$n"$'\n'
    [[ "$n" == "$id" ]] && continue   # our own window closes when we exit
    win=$(node_field "$n" window)
    window_alive "$win" && tmux kill-window -t "$win" 2>/dev/null || true
  done
  jq_update --argjson ids "$(printf '%s' "$pruned" | jq -R . | jq -s .)" \
    'map(if (.id as $i | $ids | index($i)) then .window="" | .pane="" else . end)'
  tmux set-option -p -u @lemux_session 2>/dev/null || true
  if [[ -n "$p" ]]; then
    win=$(node_field "$p" window)
    window_alive "$win" && tmux select-window -t "$win" 2>/dev/null || true
  fi
}

cmd__list() { # [root_id] — tab-separated: id <TAB> rendered tree line
  init_state
  if [[ -n "${1:-}" ]]; then
    _walk "$1" "" root
    return 0
  fi
  # Topics are per-folder, like claude --resume: list only this folder's.
  local r
  for r in $(jq -r --arg d "$PWD" \
      '[.[] | select(.parent=="" and .dir==$d)] | sort_by(.created) | .[].id' "$TREE"); do
    _walk "$r" "" root
  done
}

_walk() { # id prefix position(root|mid|last)
  local id="$1" prefix="$2" pos="$3" glyph=""
  local child_prefix="$prefix"
  case "$pos" in
    mid)  glyph="├─ "; child_prefix="${prefix}│  " ;;
    last) glyph="└─ "; child_prefix="${prefix}   " ;;
  esac
  local status="○"
  window_alive "$(node_field "$id" window)" && status="●"
  printf '%s\t%s%s%s %s\n' "$id" "$prefix" "$glyph" "$status" "$(node_field "$id" name)"
  local kids i n
  kids=($(jq -r --arg id "$id" '[.[] | select(.parent==$id)] | sort_by(.created) | .[].id' "$TREE"))
  n=${#kids[@]}
  for ((i = 0; i < n; i++)); do
    if ((i == n - 1)); then _walk "${kids[$i]}" "$child_prefix" last
    else _walk "${kids[$i]}" "$child_prefix" mid; fi
  done
}

cmd_tree() { # <pane_id> — fzf navigator over this session's own side quests
  init_state
  local pane="${1:?usage: lemux tree <pane_id>}" cur root self out
  cur=$(tmux display-message -t "$pane" -p '#{@lemux_session}' 2>/dev/null || true)
  [[ -n "$cur" ]] || popup_die "this pane is not a lemux session — start one with: lemux start"
  root=$(root_of "$cur")
  [[ -n "$(node_field "$root" name)" ]] || popup_die "unknown session $cur"
  self=$(printf '%q' "$SELF")
  out=$(cmd__list "$root" | fzf --delimiter='\t' --with-nth=2 --no-sort --layout=reverse \
    --prompt='lemux> ' \
    --header='enter: jump · ctrl-x: delete branch · esc: close' \
    --preview="$self _preview {1}" --preview-window=right,55%,wrap \
    --bind="ctrl-x:execute-silent($self rm {1})+reload($self _list $root)") || return 0
  cmd_jump "${out%%$'\t'*}"
}

cmd_jump() { # id — focus the branch's window, reviving it if closed
  local id="${1:?usage: lemux jump <id>}" win
  win=$(node_field "$id" window)
  if window_alive "$win"; then
    tmux select-window -t "$win"
  else
    local dir name
    dir=$(node_field "$id" dir)
    name=$(node_field "$id" name)
    [[ -n "$dir" ]] || die "unknown session $id"
    tmux new-window -c "$dir" -n "$name" \
      "exec $(printf '%q' "$SELF") _run $(printf '%q' "$id") $(printf '%q' "$dir") revive"
  fi
}

cmd_rm() { # <topic-name | id> | --pane <pane_id> — delete a branch or untrack a topic
  init_state
  local id=""
  while (($#)); do
    case "$1" in
      --pane) shift; id=$(tmux display-message -t "${1:?}" -p '#{@lemux_session}' 2>/dev/null || true) ;;
      *)      id="$1" ;;
    esac
    shift
  done
  [[ -n "$id" ]] || die "usage: lemux rm <topic-name | id | --pane <pane_id>>"
  if [[ -z "$(node_field "$id" name)" ]]; then
    # not an id — resolve it as a topic name in this folder
    local matches
    matches=($(jq -r --arg n "$id" --arg d "$PWD" \
      '.[] | select(.parent=="" and .name==$n and .dir==$d) | .id' "$TREE"))
    case ${#matches[@]} in
      0) die "no topic named '$id' in this folder (topics are per-folder, like claude --resume)" ;;
      1) id="${matches[0]}" ;;
      *) die "several topics here are named '$id' — rm by id: ${matches[*]}" ;;
    esac
  fi

  local ids n root_parent
  ids=($(descendants "$id"))
  root_parent=$(node_field "$id" parent)
  for n in "${ids[@]}"; do
    local win dir
    win=$(node_field "$n" window)
    window_alive "$win" && tmux kill-window -t "$win" 2>/dev/null || true
    # Root transcripts are never auto-deleted; branch transcripts are.
    if ! { [[ "$n" == "$id" ]] && [[ -z "$root_parent" ]]; }; then
      dir=$(node_field "$n" dir)
      rm -f "$(session_file "$n" "$dir")"
    fi
  done
  local json_ids
  json_ids=$(printf '%s\n' "${ids[@]}" | jq -R . | jq -s .)
  jq_update --argjson dead "$json_ids" 'map(select(.id as $i | $dead | index($i) | not))'
}

cmd__preview() { # id — branch info + transcript tail, for the fzf preview pane
  init_state
  local id="${1:?}" name excerpt dir file
  name=$(node_field "$id" name)
  excerpt=$(node_field "$id" excerpt)
  dir=$(node_field "$id" dir)
  printf '%s\n' "$name"
  printf 'session %s\n' "$id"
  if [[ -n "$excerpt" ]]; then
    printf '\nbranched on:\n"%s"\n' "$excerpt"
  fi
  printf '\n─────────────────────────\n'
  file=$(session_file "$id" "$dir")
  if [[ ! -f "$file" ]]; then
    printf '(no messages yet)\n'
    return 0
  fi
  tail -n 400 "$file" | jq -r '
    select(.type=="user" or .type=="assistant")
    | {p: (if .type=="user" then "you ▸ " else "claude ▸ " end), c: (.message.content // "")}
    | .c = (if (.c|type)=="string" then .c
            elif (.c|type)=="array" then ([.c[] | select(type=="object" and .type=="text") | .text] | join(" "))
            else "" end)
    | select(.c != "")
    | .p + (.c | gsub("\\s+"; " ") | .[0:400])
  ' 2>/dev/null | tail -n 14 || printf '(could not parse transcript)\n'
}

cmd_ls() { cmd__list | cut -f2-; }

cmd_init() { # print tmux keybindings (absolute paths — PATH-proof)
  local self
  self=$(printf '%q' "$SELF")
  cat <<EOF

# >>> lemux >>>
# prefix + B          branch on the text you just copied (select + cmd-C first)
# prefix + T          open the branch tree navigator
# prefix + X          delete the current pane's branch (+ subtree)
bind-key B run-shell "$self _popup 78% 45% ask '#{pane_id}'"
bind-key T run-shell "$self _popup 85% 70% tree '#{pane_id}'"
bind-key X confirm-before -p "lemux: delete this branch and its subtree? (y/n)" "run-shell \"$self rm --pane '#{pane_id}'\""
# <<< lemux <<<
EOF
}

cmd_help() {
  cat <<'EOF'
lemux — tmux-native navigator for branched Claude Code sessions

  lemux start <name>     enter a topic — resumes it if it exists, creates it if not
  lemux tree <pane>      fzf navigator over that session's own side quests
  lemux ls               print this folder's topics (like claude --resume)
  lemux ask <pane>       branch popup: copied text + a question
  lemux branch <pane>    fork the pane's session (--text <excerpt> --ask <q>)
  lemux jump <id>        focus a branch, reviving its window if closed
  lemux rm <name|id>     branch: delete it + its subtree (transcripts too)
                         topic name: untrack the topic — side-quest transcripts
                         are deleted, the root conversation is kept
  lemux init             print tmux keybindings (append to ~/.tmux.conf)

Typical flow: lemux start → chat → select text with the mouse and hit cmd-C →
prefix+B, type your question → side quest opens as a fork with the full parent
context → prefix+T to jump around → prefix+X to throw a side quest away.
EOF
}

# ---------- dispatch ----------

case "${1:-help}" in
  start)    shift; cmd_start "$@" ;;
  branch)   shift; cmd_branch "$@" ;;
  ask)      shift; cmd_ask "$@" ;;
  tree)     shift; cmd_tree "$@" ;;
  jump)     shift; cmd_jump "$@" ;;
  rm)       shift; cmd_rm "$@" ;;
  ls)       shift; cmd_ls "$@" ;;
  init)     shift; cmd_init "$@" ;;
  _list)    shift; cmd__list "$@" ;;
  _popup)   shift; cmd__popup "$@" ;;
  _type)    shift; cmd__type "$@" ;;
  _preview) shift; cmd__preview "$@" ;;
  _run)     shift; cmd__run "$@" ;;
  help|-h|--help) cmd_help ;;
  *) die "unknown command: $1 (try: lemux help)" ;;
esac
